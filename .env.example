# Application
APP_NAME=ResQBite
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Database
DATABASE_URL=mysql+pymysql://resqbite_user:securepassword@db:3306/resqbite_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Priority Claim Timer (minutes NGOs have exclusive claim window)
NGO_CLAIM_WINDOW_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Notification (mock / redis / email)
NOTIFICATION_BACKEND=mock

# Redis (optional, for queue-ready notifications)
# REDIS_URL=redis://redis:6379/0
